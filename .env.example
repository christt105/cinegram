# Environment variables for Cinegram - Example Template
JELLYFIN_URL=http://192.168.1.15:8096
JELLYFIN_TOKEN=your_jellyfin_token_here

# Telegram Bot configuration
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_AUTH_USER_ID=your_telegram_user_id_here

# TMDB configuration
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_CONTENT_LANGUAGE=en-US   # Language for movie/series titles and overviews (e.g. es-ES, fr-FR)

# Host paths for media directories
IMPORT_MOVIES_DIR=/mnt/disco/70-79_Media/Peliculas
IMPORT_SHOWS_DIR=/mnt/disco/70-79_Media/Series

# Docker service user and group permissions
PUID=1000
PGID=1000

# Backend configurations
BACKEND_PORT=8005
